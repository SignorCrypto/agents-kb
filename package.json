{
  "name": "agents-kb",
  "version": "0.0.18",
  "description": "The Kanban board for terminal-based agents",
  "main": "out/main/main.js",
  "scripts": {
    "start": "electron-vite dev",
    "demo": "DEMO_MODE=true electron-vite dev",
    "test": "vitest run",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "package": "pnpm build && electron-builder --dir",
    "make": "pnpm build && electron-builder",
    "make:win": "pnpm build && electron-builder  --win --x64",
    "publish": "pnpm build && electron-builder --publish always"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@anthropic-ai/sdk": "0.110.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.2.0-beta.12",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "packageManager": "pnpm@9.15.4"
}
